NODE_ENV=production

PORT=3000

DOMAIN=yourdomain.com

ACME_EMAIL=admin@yourdomain.com

TRAEFIK_AUTH=admin:$$apr1$$CHANGE_ME

DB_HOST=postgres
DB_PORT=5432
DB_NAME=spawner
DB_USER=spawner
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD

PROJECT_CONFIG_PATH=/opt/spawner/project.config.yml
GIT_KEYS_PATH=/opt/spawner/git-keys
REPOS_PATH=/opt/spawner/repos
ENVS_PATH=/opt/spawner/envs
DOCKER_SOCKET=/var/run/docker.sock

GITHUB_CLIENT_ID=your_production_github_client_id
GITHUB_CLIENT_SECRET=your_production_github_client_secret
GITHUB_CALLBACK_URL=https://spawner.yourdomain.com/api/auth/github/callback
GITHUB_ORG=your_github_organization_name
GITHUB_TEAM=your_team_slug

SESSION_SECRET=GENERATE_NEW_SECRET_WITH_openssl_rand_base64_32
SESSION_MAX_AGE=86400000

FRONTEND_URL=https://spawner.yourdomain.com
VITE_API_URL=/api

GITHUB_REPO=your-org/spawner

AUTO_UPDATE_ENABLED=false
UPDATE_CHECK_CRON=0 * * * *
AUTO_UPDATE_CRON=0 0 * * *

WEBHOOK_SECRET=GENERATE_NEW_SECRET_WITH_openssl_rand_hex_32
AUTO_DEPLOY_ENABLED=false
AUTO_DEPLOY_BRANCH=main

DEPLOY_TOKEN=GENERATE_NEW_TOKEN_WITH_openssl_rand_hex_32
