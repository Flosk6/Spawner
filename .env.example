NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=spawner
DB_PASSWORD=spawner
DB_NAME=spawner

# Development: Use local paths (change to /opt/spawner/* in production)
PROJECT_CONFIG_PATH=./local-data/project.config.yml
GIT_KEYS_PATH=./local-data/git-keys
REPOS_PATH=./local-data/repos
ENVS_PATH=./local-data/envs
DOCKER_SOCKET=/var/run/docker.sock

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
GITHUB_ORG=your_github_org_name
GITHUB_TEAM=your_team_slug

SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32
SESSION_MAX_AGE=86400000

FRONTEND_URL=http://localhost:8080

VITE_API_URL=http://localhost:3000

GITHUB_REPO=your-org/spawner

AUTO_UPDATE_ENABLED=false
UPDATE_CHECK_CRON=0 * * * *
AUTO_UPDATE_CRON=0 0 * * *

WEBHOOK_SECRET=your_webhook_secret_here
AUTO_DEPLOY_ENABLED=false
AUTO_DEPLOY_BRANCH=main

DEPLOY_TOKEN=your_deploy_token_here

DOMAIN=

ACME_EMAIL=

TRAEFIK_AUTH=
