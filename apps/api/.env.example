# OAuth & Session
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
GITHUB_ORG=your_organization_name
GITHUB_TEAM=your_team_slug
SESSION_SECRET=generate_with_openssl_rand_base64_32
SESSION_MAX_AGE=86400000
FRONTEND_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://spawner:spawner@localhost:5432/spawner
DB_HOST=localhost
DB_PORT=5432
DB_USER=spawner
DB_PASSWORD=spawner
DB_NAME=spawner

# Application
NODE_ENV=development
PORT=3000

# Paths (use absolute paths in production)
GIT_KEYS_PATH=/opt/spawner/git-keys
REPOS_PATH=/opt/spawner/repos
ENVS_PATH=/opt/spawner/envs
DOCKER_SOCKET=/var/run/docker.sock
